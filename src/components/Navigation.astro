---
import { mainNavigation } from '../config/navigation';
import Brand from './Brand.astro';

const navItems = mainNavigation;
---

<header class="site-header" data-site-header>
	<div class="site-header__inner container">
		<Brand href="/" class="site-header__brand" />

		<button
			type="button"
			class="nav-toggle nav-toggle--open"
			aria-expanded="false"
			aria-controls="site-nav"
			aria-label="Menü öffnen"
		>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
		</button>
	</div>

	<div class="nav-overlay" data-nav-overlay hidden></div>

	<nav id="site-nav" class="site-nav" aria-label="Hauptnavigation" hidden>
		<div class="site-nav__head container">
			<Brand href="/" class="site-nav__brand" />

			<button type="button" class="nav-toggle nav-toggle--close" aria-label="Menü schließen">
				<span class="nav-toggle__bar" aria-hidden="true"></span>
				<span class="nav-toggle__bar" aria-hidden="true"></span>
				<span class="nav-toggle__bar" aria-hidden="true"></span>
			</button>
		</div>

		<div class="site-nav__body container">
			<ul class="site-nav__list">
				{
					navItems.map((item) => (
						<li class="site-nav__item">
							<a href={item.href} class="site-nav__link" data-nav-link>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		height: var(--header-height);
		background-color: var(--color-cream);
		box-shadow: var(--shadow-header);
		isolation: isolate;
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 100%;
	}

	.site-header__brand {
		min-height: var(--touch-min);
		padding-inline: var(--space-2xs);
	}

	.nav-toggle {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 0.3125rem;
		flex-shrink: 0;
		width: var(--touch-min);
		height: var(--touch-min);
		border-radius: var(--radius-sm);
		color: var(--color-brown);
	}

	.nav-toggle:focus-visible {
		outline: 2px solid var(--color-apricot);
		outline-offset: 3px;
	}

	.nav-toggle__bar {
		display: block;
		width: 1.25rem;
		height: 1px;
		background-color: currentColor;
		transition:
			transform var(--transition-fast),
			opacity var(--transition-fast);
	}

	.nav-toggle--open[aria-expanded='true'] .nav-toggle__bar:nth-child(1) {
		transform: translateY(0.4375rem) rotate(45deg);
	}

	.nav-toggle--open[aria-expanded='true'] .nav-toggle__bar:nth-child(2) {
		opacity: 0;
	}

	.nav-toggle--open[aria-expanded='true'] .nav-toggle__bar:nth-child(3) {
		transform: translateY(-0.4375rem) rotate(-45deg);
	}

	.nav-toggle--close .nav-toggle__bar:nth-child(1) {
		transform: translateY(0.4375rem) rotate(45deg);
	}

	.nav-toggle--close .nav-toggle__bar:nth-child(2) {
		opacity: 0;
	}

	.nav-toggle--close .nav-toggle__bar:nth-child(3) {
		transform: translateY(-0.4375rem) rotate(-45deg);
	}

	.nav-overlay {
		position: fixed;
		inset: 0;
		z-index: 110;
		background-color: rgb(74 52 40 / 0.22);
		opacity: 0;
		transition: opacity 220ms ease;
		pointer-events: none;
	}

	.nav-overlay.is-visible {
		opacity: 1;
		pointer-events: auto;
	}

	.site-nav {
		position: fixed;
		inset: 0;
		z-index: 120;
		display: flex;
		flex-direction: column;
		background-color: var(--color-cream);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		padding-top: env(safe-area-inset-top, 0);
		opacity: 0;
		transition: opacity 220ms ease;
		pointer-events: none;
	}

	.site-nav.is-open {
		opacity: 1;
		pointer-events: auto;
	}

	.site-nav__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-shrink: 0;
		min-height: var(--header-height);
		border-bottom: 1px solid rgb(74 52 40 / 0.08);
	}

	.site-nav__brand {
		min-height: var(--touch-min);
		padding-inline: var(--space-2xs);
	}

	.site-nav__body {
		flex: 1;
		padding-block: var(--space-lg) var(--space-2xl);
	}

	.site-nav__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-nav__item + .site-nav__item {
		border-top: 1px solid rgb(74 52 40 / 0.06);
	}

	.site-nav__link {
		display: flex;
		align-items: center;
		min-height: var(--touch-min);
		padding: var(--space-sm) 0;
		font-family: var(--font-display);
		font-size: clamp(1.125rem, 3.8vw, 1.3125rem);
		font-weight: 400;
		line-height: 1.25;
		letter-spacing: -0.01em;
		color: var(--color-brown);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.site-nav__link:hover {
		color: var(--color-apricot-dark);
	}

	.site-nav__link:focus-visible {
		outline: 2px solid var(--color-apricot);
		outline-offset: 4px;
		color: var(--color-brown);
	}

	.site-header.is-menu-open .site-header__inner {
		visibility: hidden;
	}

	@media (min-width: 64rem) {
		.nav-toggle,
		.nav-overlay,
		.site-nav__head {
			display: none;
		}

		.site-header.is-menu-open .site-header__inner {
			visibility: visible;
		}

		.site-nav {
			position: absolute;
			inset: auto;
			top: 0;
			right: var(--page-gutter);
			display: flex !important;
			flex-direction: row;
			align-items: center;
			width: auto;
			height: var(--header-height);
			padding: 0;
			background: none;
			overflow: visible;
			opacity: 1;
			pointer-events: auto;
		}

		.site-nav__body {
			padding: 0;
		}

		.site-header__inner {
			gap: var(--space-lg);
		}

		.site-header {
			display: flex;
			align-items: center;
		}

		.site-header > .container.site-header__inner {
			flex: 1;
		}

		.site-nav__list {
			flex-direction: row;
			gap: var(--space-2xs);
		}

		.site-nav__item + .site-nav__item {
			border-top: none;
		}

		.site-nav__link {
			min-height: var(--touch-min);
			padding: var(--space-xs) var(--space-md);
			font-family: var(--font-body);
			font-size: var(--text-base);
			font-weight: 500;
			letter-spacing: 0;
			color: var(--color-black);
			border-radius: var(--radius-md);
			transition:
				background-color var(--transition-fast),
				color var(--transition-fast);
		}

		.site-nav__link:hover,
		.site-nav__link:focus-visible {
			background-color: rgb(217 160 102 / 0.12);
			color: var(--color-brown);
		}
	}
</style>

<script>
	const header = document.querySelector('[data-site-header]');
	const toggleOpen = document.querySelector('.nav-toggle--open');
	const toggleClose = document.querySelector('.nav-toggle--close');
	const nav = document.getElementById('site-nav');
	const overlay = document.querySelector('[data-nav-overlay]');
	const navLinks = document.querySelectorAll('[data-nav-link], .site-nav__brand');
	const desktopQuery = window.matchMedia('(min-width: 64rem)');

	function setMenuOpen(open: boolean) {
		if (!toggleOpen || !nav || !overlay || !header) return;

		toggleOpen.setAttribute('aria-expanded', String(open));
		header.classList.toggle('is-menu-open', open);
		nav.classList.toggle('is-open', open);
		overlay.classList.toggle('is-visible', open);
		nav.hidden = !open;
		overlay.hidden = !open;
		document.body.style.overflow = open ? 'hidden' : '';
	}

	function closeMenu() {
		if (!desktopQuery.matches) setMenuOpen(false);
	}

	toggleOpen?.addEventListener('click', () => {
		const isOpen = toggleOpen.getAttribute('aria-expanded') === 'true';
		setMenuOpen(!isOpen);
	});

	toggleClose?.addEventListener('click', closeMenu);
	overlay?.addEventListener('click', closeMenu);
	navLinks.forEach((link) => link.addEventListener('click', closeMenu));

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeMenu();
	});

	function handleViewportChange() {
		if (!nav || !overlay || !toggleOpen || !header) return;

		if (desktopQuery.matches) {
			nav.hidden = false;
			overlay.hidden = true;
			nav.classList.remove('is-open');
			overlay.classList.remove('is-visible');
			header.classList.remove('is-menu-open');
			toggleOpen.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		} else if (toggleOpen.getAttribute('aria-expanded') !== 'true') {
			nav.hidden = true;
			overlay.hidden = true;
			header.classList.remove('is-menu-open');
		}
	}

	desktopQuery.addEventListener('change', handleViewportChange);
	handleViewportChange();
</script>
