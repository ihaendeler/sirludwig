---
import { mainNavigation } from '../config/navigation';
import Brand from './Brand.astro';

const navItems = mainNavigation;
---

<header class="site-header">
	<div class="site-header__inner container">
		<Brand href="/" class="site-header__brand" />

		<button
			type="button"
			class="nav-toggle"
			aria-expanded="false"
			aria-controls="site-nav"
			aria-label="Menü öffnen"
		>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
			<span class="nav-toggle__bar" aria-hidden="true"></span>
		</button>
	</div>

	<div class="nav-overlay" data-nav-overlay hidden></div>

	<nav id="site-nav" class="site-nav" aria-label="Hauptnavigation" hidden>
		<div class="site-nav__intro">
			<Brand href="/" class="site-nav__brand" />
		</div>

		<ul class="site-nav__list">
			{
				navItems.map((item) => (
					<li class="site-nav__item">
						<a href={item.href} class="site-nav__link" data-nav-link>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		height: var(--header-height);
		background-color: var(--color-cream);
		box-shadow: var(--shadow-header);
		isolation: isolate;
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 100%;
	}

	.site-header__brand {
		min-height: var(--touch-min);
		padding-inline: var(--space-2xs);
	}

	.nav-toggle {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 0.3125rem;
		width: var(--touch-min);
		height: var(--touch-min);
		border-radius: var(--radius-sm);
		color: var(--color-brown);
	}

	.nav-toggle:focus-visible {
		outline: 2px solid var(--color-apricot);
		outline-offset: 3px;
	}

	.nav-toggle__bar {
		display: block;
		width: 1.25rem;
		height: 1px;
		background-color: currentColor;
		transition:
			transform var(--transition-fast),
			opacity var(--transition-fast);
	}

	.nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(1) {
		transform: translateY(0.4375rem) rotate(45deg);
	}

	.nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(2) {
		opacity: 0;
	}

	.nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(3) {
		transform: translateY(-0.4375rem) rotate(-45deg);
	}

	.nav-overlay {
		position: fixed;
		inset: 0;
		z-index: 110;
		background-color: rgb(74 52 40 / 0.22);
		opacity: 0;
		transition: opacity 220ms ease;
		pointer-events: none;
	}

	.nav-overlay.is-visible {
		opacity: 1;
		pointer-events: auto;
	}

	.site-nav {
		position: fixed;
		inset: var(--header-height) 0 0 0;
		z-index: 120;
		display: flex;
		flex-direction: column;
		padding: var(--space-xl) var(--page-gutter) var(--space-2xl);
		background-color: var(--color-cream);
		border-top: 1px solid rgb(74 52 40 / 0.1);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		opacity: 0;
		transition: opacity 220ms ease;
		pointer-events: none;
	}

	.site-nav.is-open {
		opacity: 1;
		pointer-events: auto;
	}

	.site-nav__intro {
		margin-bottom: var(--space-xl);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid rgb(74 52 40 / 0.1);
	}

	.site-nav__brand :global(.brand__name) {
		font-size: 1.25rem;
		letter-spacing: 0.05em;
	}

	.site-nav__brand :global(.brand__tagline) {
		font-size: 0.75rem;
	}

	.site-nav__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-nav__item + .site-nav__item {
		border-top: 1px solid rgb(74 52 40 / 0.1);
	}

	.site-nav__link {
		display: flex;
		align-items: center;
		min-height: var(--touch-min);
		padding: var(--space-md) 0;
		font-family: var(--font-display);
		font-size: clamp(1.25rem, 4.5vw, 1.4375rem);
		font-weight: 400;
		line-height: 1.2;
		letter-spacing: -0.015em;
		color: var(--color-brown);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.site-nav__link:hover {
		color: var(--color-apricot-dark);
	}

	.site-nav__link:focus-visible {
		outline: 2px solid var(--color-apricot);
		outline-offset: 4px;
		color: var(--color-brown);
	}

	@media (min-width: 64rem) {
		.nav-toggle,
		.nav-overlay,
		.site-nav__intro {
			display: none;
		}

		.site-nav {
			position: absolute;
			inset: auto;
			top: 0;
			right: var(--page-gutter);
			display: flex !important;
			flex-direction: row;
			align-items: center;
			height: var(--header-height);
			padding: 0;
			background: none;
			border-top: none;
			overflow: visible;
			opacity: 1;
			pointer-events: auto;
		}

		.site-header__inner {
			gap: var(--space-lg);
		}

		.site-header {
			display: flex;
			align-items: center;
		}

		.site-header > .container.site-header__inner {
			flex: 1;
		}

		.site-nav__list {
			flex-direction: row;
			gap: var(--space-2xs);
		}

		.site-nav__item + .site-nav__item {
			border-top: none;
		}

		.site-nav__link {
			min-height: var(--touch-min);
			padding: var(--space-xs) var(--space-md);
			font-family: var(--font-body);
			font-size: var(--text-base);
			font-weight: 500;
			letter-spacing: 0;
			color: var(--color-black);
			border-radius: var(--radius-md);
			transition: background-color var(--transition-fast), color var(--transition-fast);
		}

		.site-nav__link:hover,
		.site-nav__link:focus-visible {
			background-color: rgb(217 160 102 / 0.12);
			color: var(--color-brown);
		}
	}
</style>

<script>
	const toggle = document.querySelector('.nav-toggle');
	const nav = document.getElementById('site-nav');
	const overlay = document.querySelector('[data-nav-overlay]');
	const navLinks = document.querySelectorAll('[data-nav-link], .site-nav__brand');
	const desktopQuery = window.matchMedia('(min-width: 64rem)');

	function setMenuOpen(open: boolean) {
		if (!toggle || !nav || !overlay) return;

		toggle.setAttribute('aria-expanded', String(open));
		toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
		nav.classList.toggle('is-open', open);
		overlay.classList.toggle('is-visible', open);
		nav.hidden = !open;
		overlay.hidden = !open;
		document.body.style.overflow = open ? 'hidden' : '';
	}

	function closeMenu() {
		if (!desktopQuery.matches) setMenuOpen(false);
	}

	toggle?.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') === 'true';
		setMenuOpen(!isOpen);
	});

	overlay?.addEventListener('click', closeMenu);
	navLinks.forEach((link) => link.addEventListener('click', closeMenu));

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeMenu();
	});

	function handleViewportChange() {
		if (!nav || !overlay || !toggle) return;

		if (desktopQuery.matches) {
			nav.hidden = false;
			overlay.hidden = true;
			nav.classList.remove('is-open');
			overlay.classList.remove('is-visible');
			toggle.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		} else if (toggle.getAttribute('aria-expanded') !== 'true') {
			nav.hidden = true;
			overlay.hidden = true;
		}
	}

	desktopQuery.addEventListener('change', handleViewportChange);
	handleViewportChange();
</script>
