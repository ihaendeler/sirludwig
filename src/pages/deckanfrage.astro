---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig, getCanonical } from '../config/site';
import {
	dnaOptions,
	edOptions,
	existingLittersOptions,
	eyeOptions,
	federalStateOptions,
	hdOptions,
	patellaOptions,
} from '../data/deckanfrage-options';
import '../styles/deckanfrage.css';

const path = '/deckanfrage';
---

<BaseLayout
	title={`Deckanfrage — ${siteConfig.brandName}`}
	description="Deckanfrage für Sir Ludwig — Formular zur ersten Einschätzung. Der Bereich wird schrittweise vorbereitet."
	canonical={getCanonical(path)}
>
	<PageHero
		label="Deckanfrage"
		title="Deckanfrage"
		intro="Informationen zur Hündin und zum geplanten Wurf helfen bei der ersten Einschätzung."
		headingId="inquiry-heading"
	/>

	<section class="inquiry-section" aria-labelledby="inquiry-form-heading">
		<div class="container">
			<h2 id="inquiry-form-heading" class="visually-hidden">Anfrageformular</h2>

			<div class="inquiry-success" data-form-success hidden>
				<p class="inquiry-success__headline">✓ Anfrage erfolgreich übermittelt</p>
				<p class="inquiry-success__lead">Vielen Dank für Ihre Deckanfrage.</p>
				<p class="inquiry-success__text">
					Die Angaben wurden erfolgreich übermittelt und werden geprüft.
				</p>
				<a href="/" class="btn btn--primary inquiry-success__cta">Zur Startseite</a>
			</div>

			<form
				class="inquiry-form"
				action="/api/deckanfrage"
				method="post"
				novalidate
				data-inquiry-form
			>
				<input type="hidden" name="_form-started-at" value="" data-form-started-at />

				<div class="inquiry-form__honeypot" aria-hidden="true">
					<label class="inquiry-field__label" for="_honeypot">Website</label>
					<input
						class="inquiry-field__input"
						type="text"
						id="_honeypot"
						name="_honeypot"
						tabindex="-1"
						autocomplete="off"
					/>
				</div>
				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Kontaktdaten</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="contact-name">Name</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="contact-name"
								name="contact-name"
								autocomplete="name"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="contact-city">Ort / Stadt</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="contact-city"
								name="contact-city"
								autocomplete="address-level2"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="contact-state">Bundesland</label>
							<select
								class="inquiry-field__select"
								id="contact-state"
								name="contact-state"
								autocomplete="address-level1"
							>
								{federalStateOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group" data-comm-section>
					<legend class="inquiry-form__legend">Bevorzugte Kommunikation</legend>
					<p class="inquiry-field__hint">Wählen Sie, wie Sie kontaktiert werden möchten.</p>

					<div class="inquiry-comm__choices" role="group" aria-label="Bevorzugte Kommunikationswege">
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="email"
								data-comm-toggle="email"
							/>
							<span class="inquiry-check__label">E-Mail</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="phone"
								data-comm-toggle="phone"
							/>
							<span class="inquiry-check__label">Telefon</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="whatsapp"
								data-comm-toggle="whatsapp"
							/>
							<span class="inquiry-check__label">WhatsApp</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="instagram"
								data-comm-toggle="instagram"
							/>
							<span class="inquiry-check__label">Instagram</span>
						</label>
					</div>

					<p class="inquiry-comm__error" data-comm-error hidden>
						Bitte mindestens einen Kommunikationsweg auswählen.
					</p>

					<div class="inquiry-form__grid inquiry-comm__fields">
						<div class="inquiry-field inquiry-field--full inquiry-comm__field" data-comm-field="email">
							<label class="inquiry-field__label" for="comm-email">E-Mail-Adresse</label>
							<input
								class="inquiry-field__input"
								type="email"
								id="comm-email"
								name="comm-email"
								autocomplete="email"
								inputmode="email"
								data-comm-input
							/>
						</div>
						<div class="inquiry-field inquiry-field--full inquiry-comm__field" data-comm-field="phone">
							<label class="inquiry-field__label" for="comm-phone">Telefonnummer</label>
							<input
								class="inquiry-field__input"
								type="tel"
								id="comm-phone"
								name="comm-phone"
								autocomplete="tel"
								inputmode="tel"
								data-comm-input
							/>
						</div>
						<div
							class="inquiry-field inquiry-field--full inquiry-comm__field"
							data-comm-field="whatsapp"
						>
							<label class="inquiry-field__label" for="comm-whatsapp">WhatsApp-Nummer</label>
							<input
								class="inquiry-field__input"
								type="tel"
								id="comm-whatsapp"
								name="comm-whatsapp"
								autocomplete="tel"
								inputmode="tel"
								data-comm-input
							/>
							<p class="inquiry-field__hint">Kann mit der Telefonnummer identisch sein.</p>
						</div>
						<div
							class="inquiry-field inquiry-field--full inquiry-comm__field"
							data-comm-field="instagram"
						>
							<label class="inquiry-field__label" for="comm-instagram">Instagram-Profil</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="comm-instagram"
								name="comm-instagram"
								autocomplete="off"
								placeholder="@nutzername"
								data-comm-input
							/>
						</div>
					</div>

					<p class="inquiry-form__privacy">
						Die Angaben werden ausschließlich zur Bearbeitung der Deckanfrage verwendet.
						<a class="inquiry-form__privacy-link" href="/datenschutz">Datenschutzerklärung</a>
					</p>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Hündin</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="bitch-name">Name der Hündin</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-name"
								name="bitch-name"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-birthdate">Geburtsdatum</label>
							<input
								class="inquiry-field__input"
								type="date"
								id="bitch-birthdate"
								name="bitch-birthdate"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-color">Farbe</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-color"
								name="bitch-color"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-size">Größe</label>
							<div class="inquiry-field__control inquiry-field__control--unit">
								<input
									class="inquiry-field__input"
									type="number"
									id="bitch-size"
									name="bitch-size"
									min="1"
									max="99"
									step="1"
									inputmode="numeric"
									placeholder="58"
								/>
								<span class="inquiry-field__unit" aria-hidden="true">cm</span>
							</div>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-weight">Gewicht</label>
							<div class="inquiry-field__control inquiry-field__control--unit">
								<input
									class="inquiry-field__input"
									type="number"
									id="bitch-weight"
									name="bitch-weight"
									min="1"
									max="99"
									step="0.1"
									inputmode="decimal"
									placeholder="23"
								/>
								<span class="inquiry-field__unit" aria-hidden="true">kg</span>
							</div>
						</div>
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="bitch-club">Verein / Verband</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-club"
								name="bitch-club"
							/>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Gesundheit</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-hd">HD</label>
							<select class="inquiry-field__select" id="health-hd" name="health-hd">
								{hdOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-ed">ED</label>
							<select class="inquiry-field__select" id="health-ed" name="health-ed">
								{edOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-patella">Patella</label>
							<select class="inquiry-field__select" id="health-patella" name="health-patella">
								{patellaOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-eyes">Augenuntersuchung</label>
							<select class="inquiry-field__select" id="health-eyes" name="health-eyes">
								{eyeOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="health-dna">DNA-Tests</label>
							<select class="inquiry-field__select" id="health-dna" name="health-dna">
								{dnaOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Planung</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="plan-period">Geplanter Deckzeitraum</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="plan-period"
								name="plan-period"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="plan-existing-litters"
								>Bereits vorhandene Würfe?</label
							>
							<select
								class="inquiry-field__select"
								id="plan-existing-litters"
								name="plan-existing-litters"
							>
								{existingLittersOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))}
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Nachricht</legend>
					<div class="inquiry-field">
						<label class="inquiry-field__label" for="message">Freitextfeld</label>
						<textarea
							class="inquiry-field__textarea"
							id="message"
							name="message"
							rows="6"></textarea>
					</div>
				</fieldset>

				<div class="inquiry-form__consent">
					<div class="inquiry-consent">
						<input
							class="inquiry-consent__input"
							type="checkbox"
							id="privacy-consent"
							name="privacy-consent"
							value="yes"
							required
							data-privacy-consent
						/>
						<div class="inquiry-consent__content">
							<label class="inquiry-consent__label" for="privacy-consent">
								Ich habe die{' '}
								<a class="inquiry-form__privacy-link" href="/datenschutz" data-consent-link>
									Datenschutzerklärung
								</a>{' '}
								gelesen und bin damit einverstanden, dass meine Angaben zur Bearbeitung der
								Deckanfrage verarbeitet werden.
							</label>
							<p class="inquiry-consent__hint">
								Die Angaben werden ausschließlich zur Bearbeitung der Anfrage verwendet.
							</p>
						</div>
					</div>
				</div>

				<div class="inquiry-form__actions">
					<p class="inquiry-form__status inquiry-form__status--error" data-form-error hidden role="alert"></p>

					<button
						type="submit"
						class="btn btn--primary inquiry-form__submit"
						disabled
						data-inquiry-submit
					>
						Anfrage absenden
					</button>
				</div>
			</form>
		</div>
	</section>

	<section class="inquiry-notice" aria-labelledby="inquiry-notice-heading">
		<div class="container">
			<div class="inquiry-notice__inner">
				<p class="inquiry-eyebrow">Hinweis</p>
				<h2 id="inquiry-notice-heading" class="inquiry-title">Aktueller Stand</h2>
				<p class="inquiry-text">
					Ludwig befindet sich aktuell im Aufbau als zukünftiger Deckrüde. Die Seite dient der
					Dokumentation seiner Entwicklung. Verfügbarkeiten und Voraussetzungen werden zu
					gegebener Zeit veröffentlicht.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const form = document.querySelector<HTMLFormElement>('[data-inquiry-form]');
	const formSuccess = document.querySelector<HTMLElement>('[data-form-success]');
	const commSection = document.querySelector<HTMLElement>('[data-comm-section]');
	const consentCheckbox = form?.querySelector<HTMLInputElement>('[data-privacy-consent]');
	const submitButton = form?.querySelector<HTMLButtonElement>('[data-inquiry-submit]');
	const formError = form?.querySelector<HTMLElement>('[data-form-error]');
	const formStartedAt = form?.querySelector<HTMLInputElement>('[data-form-started-at]');

	const neutralError =
		'Die Anfrage konnte derzeit nicht übermittelt werden. Bitte versuchen Sie es später erneut.';

	if (formStartedAt) {
		formStartedAt.value = String(Date.now());
	}

	function syncSubmitState() {
		if (submitButton && consentCheckbox) {
			submitButton.disabled = !consentCheckbox.checked;
		}
	}

	function hideFormError() {
		formError?.setAttribute('hidden', '');
		if (formError) formError.textContent = '';
	}

	function showFormError(message: string) {
		if (!formError) return;
		formError.textContent = message;
		formError.removeAttribute('hidden');
	}

	function showFormSuccess() {
		form?.setAttribute('hidden', '');
		formSuccess?.removeAttribute('hidden');
		formSuccess?.scrollIntoView({ behavior: 'smooth', block: 'start' });
	}

	if (form) {
		document.documentElement.classList.add('js');

		syncSubmitState();
		consentCheckbox?.addEventListener('change', syncSubmitState);

		form.querySelectorAll<HTMLAnchorElement>('[data-consent-link]').forEach((link) => {
			link.addEventListener('click', (event) => {
				event.stopPropagation();
			});
		});
	}

	if (form && commSection) {
		const toggles = commSection.querySelectorAll<HTMLInputElement>('[data-comm-toggle]');
		const commError = commSection.querySelector<HTMLElement>('[data-comm-error]');

		function syncCommFields() {
			toggles.forEach((toggle) => {
				const key = toggle.dataset.commToggle;
				const field = commSection.querySelector<HTMLElement>(`[data-comm-field="${key}"]`);
				const input = field?.querySelector<HTMLInputElement>('[data-comm-input]');
				const visible = toggle.checked;

				field?.classList.toggle('is-visible', visible);

				if (input) {
					if (visible) {
						input.removeAttribute('disabled');
					} else {
						input.setAttribute('disabled', 'disabled');
						input.setCustomValidity('');
					}
				}
			});
		}

		toggles.forEach((toggle) => {
			toggle.addEventListener('change', () => {
				commError?.setAttribute('hidden', '');
				syncCommFields();
			});
		});

		syncCommFields();

		function validateCommunication(): boolean {
			const selected = [...toggles].filter((toggle) => toggle.checked);

			if (selected.length === 0) {
				commError?.removeAttribute('hidden');
				toggles[0]?.focus();
				return false;
			}

			commError?.setAttribute('hidden', '');

			let valid = true;

			selected.forEach((toggle) => {
				const key = toggle.dataset.commToggle;
				const field = commSection.querySelector<HTMLElement>(`[data-comm-field="${key}"]`);
				const input = field?.querySelector<HTMLInputElement>('[data-comm-input]');

				if (!input) return;

				const value = input.value.trim();

				if (!value) {
					input.setCustomValidity('Bitte Angabe ergänzen.');
					valid = false;
					return;
				}

				if (key === 'email' && !input.checkValidity()) {
					input.setCustomValidity('Bitte gültige E-Mail-Adresse angeben.');
					valid = false;
					return;
				}

				input.setCustomValidity('');
			});

			if (!valid) {
				const firstInvalid = commSection.querySelector<HTMLInputElement>(
					'[data-comm-input]:invalid',
				);
				firstInvalid?.reportValidity();
			}

			return valid;
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			hideFormError();

			if (!consentCheckbox?.checked) {
				consentCheckbox?.focus();
				return;
			}

			if (!validateCommunication()) {
				return;
			}

			if (!form.reportValidity()) {
				return;
			}

			if (submitButton) {
				submitButton.disabled = true;
				submitButton.textContent = 'Wird übermittelt...';
			}

			let succeeded = false;

			try {
				const response = await fetch('/api/deckanfrage', {
					method: 'POST',
					body: new FormData(form),
					headers: {
						Accept: 'application/json',
					},
				});

				let data: { ok?: boolean; message?: string; code?: string } = {};

				try {
					data = await response.json();
				} catch {
					data = {};
				}

				if (response.ok && data.ok) {
					succeeded = true;
					showFormSuccess();
					return;
				}

				const message =
					data.code === 'missing_api_key' && data.message
						? data.message
						: data.message || neutralError;

				showFormError(message);
			} catch {
				showFormError(neutralError);
			} finally {
				if (!succeeded && submitButton) {
					submitButton.textContent = 'Anfrage absenden';
					syncSubmitState();
				}
			}
		});
	}
</script>

<style>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
