---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig, getCanonical } from '../config/site';
import '../styles/deckanfrage.css';

const path = '/deckanfrage';
---

<BaseLayout
	title={`Deckanfrage — ${siteConfig.brandName}`}
	description="Deckanfrage für Sir Ludwig — Formular zur ersten Einschätzung. Der Bereich wird schrittweise vorbereitet."
	canonical={getCanonical(path)}
>
	<PageHero
		label="Deckanfrage"
		title="Deckanfrage"
		intro="Informationen zur Hündin und zum geplanten Wurf helfen bei der ersten Einschätzung."
		headingId="inquiry-heading"
	/>

	<section class="inquiry-section" aria-labelledby="inquiry-form-heading">
		<div class="container">
			<h2 id="inquiry-form-heading" class="visually-hidden">Anfrageformular</h2>

			<form class="inquiry-form" action="#" method="post" novalidate data-inquiry-form>
				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Kontaktdaten</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="contact-name">Name</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="contact-name"
								name="contact-name"
								autocomplete="name"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="contact-email">E-Mail</label>
							<input
								class="inquiry-field__input"
								type="email"
								id="contact-email"
								name="contact-email"
								autocomplete="email"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="contact-phone">Telefon</label>
							<input
								class="inquiry-field__input"
								type="tel"
								id="contact-phone"
								name="contact-phone"
								autocomplete="tel"
							/>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group" data-comm-section>
					<legend class="inquiry-form__legend">Bevorzugte Kommunikation</legend>
					<p class="inquiry-field__hint">
						Wählen Sie, wie Sie kontaktiert werden möchten. E-Mail wird für die erste
						Kontaktaufnahme empfohlen.
					</p>

					<div class="inquiry-comm__choices" role="group" aria-label="Bevorzugte Kommunikationswege">
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="email"
								data-comm-toggle="email"
							/>
							<span class="inquiry-check__label">E-Mail</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="phone"
								data-comm-toggle="phone"
							/>
							<span class="inquiry-check__label">Telefon</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="whatsapp"
								data-comm-toggle="whatsapp"
							/>
							<span class="inquiry-check__label">WhatsApp</span>
						</label>
						<label class="inquiry-check">
							<input
								class="inquiry-check__input"
								type="checkbox"
								name="comm-pref"
								value="instagram"
								data-comm-toggle="instagram"
							/>
							<span class="inquiry-check__label">Instagram</span>
						</label>
					</div>

					<p class="inquiry-comm__error" data-comm-error hidden>
						Bitte mindestens einen Kommunikationsweg auswählen.
					</p>

					<div class="inquiry-form__grid inquiry-comm__fields">
						<div class="inquiry-field inquiry-field--full inquiry-comm__field" data-comm-field="email">
							<label class="inquiry-field__label" for="comm-email">E-Mail-Adresse</label>
							<input
								class="inquiry-field__input"
								type="email"
								id="comm-email"
								name="comm-email"
								autocomplete="email"
								inputmode="email"
								data-comm-input
							/>
						</div>
						<div class="inquiry-field inquiry-field--full inquiry-comm__field" data-comm-field="phone">
							<label class="inquiry-field__label" for="comm-phone">Telefonnummer</label>
							<input
								class="inquiry-field__input"
								type="tel"
								id="comm-phone"
								name="comm-phone"
								autocomplete="tel"
								inputmode="tel"
								data-comm-input
							/>
						</div>
						<div
							class="inquiry-field inquiry-field--full inquiry-comm__field"
							data-comm-field="whatsapp"
						>
							<label class="inquiry-field__label" for="comm-whatsapp">WhatsApp-Nummer</label>
							<input
								class="inquiry-field__input"
								type="tel"
								id="comm-whatsapp"
								name="comm-whatsapp"
								autocomplete="tel"
								inputmode="tel"
								data-comm-input
							/>
							<p class="inquiry-field__hint">Kann mit der Telefonnummer identisch sein.</p>
						</div>
						<div
							class="inquiry-field inquiry-field--full inquiry-comm__field"
							data-comm-field="instagram"
						>
							<label class="inquiry-field__label" for="comm-instagram">Instagram-Profil</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="comm-instagram"
								name="comm-instagram"
								autocomplete="off"
								placeholder="@nutzername"
								data-comm-input
							/>
						</div>
					</div>

					<p class="inquiry-field__hint inquiry-field__hint--privacy">
						Für die Bearbeitung Ihrer Anfrage werden die angegebenen Kontaktdaten (E-Mail-Adresse,
						Telefonnummer, WhatsApp-Nummer, Instagram-Profil) verarbeitet.
					</p>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Hündin</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="bitch-name">Name der Hündin</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-name"
								name="bitch-name"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-birthdate">Geburtsdatum</label>
							<input
								class="inquiry-field__input"
								type="date"
								id="bitch-birthdate"
								name="bitch-birthdate"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-color">Farbe</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-color"
								name="bitch-color"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-size">Größe</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-size"
								name="bitch-size"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="bitch-weight">Gewicht</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-weight"
								name="bitch-weight"
							/>
						</div>
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="bitch-club">Verein / Verband</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="bitch-club"
								name="bitch-club"
							/>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Gesundheit</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-hd">HD</label>
							<input class="inquiry-field__input" type="text" id="health-hd" name="health-hd" />
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-ed">ED</label>
							<input class="inquiry-field__input" type="text" id="health-ed" name="health-ed" />
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-patella">Patella</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="health-patella"
								name="health-patella"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="health-eyes">Augenuntersuchung</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="health-eyes"
								name="health-eyes"
							/>
						</div>
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="health-dna">DNA-Tests</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="health-dna"
								name="health-dna"
							/>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Planung</legend>
					<div class="inquiry-form__grid">
						<div class="inquiry-field inquiry-field--full">
							<label class="inquiry-field__label" for="plan-period">Geplanter Deckzeitraum</label>
							<input
								class="inquiry-field__input"
								type="text"
								id="plan-period"
								name="plan-period"
							/>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="plan-first-litter">Erster Wurf?</label>
							<select class="inquiry-field__select" id="plan-first-litter" name="plan-first-litter">
								<option value="">Bitte wählen</option>
								<option value="ja">Ja</option>
								<option value="nein">Nein</option>
							</select>
						</div>
						<div class="inquiry-field">
							<label class="inquiry-field__label" for="plan-existing-litters"
								>Bereits vorhandene Würfe?</label
							>
							<select
								class="inquiry-field__select"
								id="plan-existing-litters"
								name="plan-existing-litters"
							>
								<option value="">Bitte wählen</option>
								<option value="ja">Ja</option>
								<option value="nein">Nein</option>
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset class="inquiry-form__group">
					<legend class="inquiry-form__legend">Nachricht</legend>
					<div class="inquiry-field">
						<label class="inquiry-field__label" for="message">Freitextfeld</label>
						<textarea
							class="inquiry-field__textarea"
							id="message"
							name="message"
							rows="6"></textarea>
					</div>
				</fieldset>

				<div class="inquiry-form__actions">
					<button type="submit" class="btn btn--primary inquiry-form__submit" disabled>
						Absenden — demnächst verfügbar
					</button>
					<p class="inquiry-form__note">Versand wird zu gegebener Zeit aktiviert.</p>
				</div>
			</form>
		</div>
	</section>

	<section class="inquiry-notice" aria-labelledby="inquiry-notice-heading">
		<div class="container">
			<div class="inquiry-notice__inner">
				<p class="inquiry-eyebrow">Hinweis</p>
				<h2 id="inquiry-notice-heading" class="inquiry-title">Aktueller Stand</h2>
				<p class="inquiry-text">
					Ludwig befindet sich aktuell im Aufbau als zukünftiger Deckrüde. Die Seite dient der
					Dokumentation seiner Entwicklung. Verfügbarkeiten und Voraussetzungen werden zu
					gegebener Zeit veröffentlicht.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const form = document.querySelector<HTMLFormElement>('[data-inquiry-form]');
	const commSection = document.querySelector<HTMLElement>('[data-comm-section]');

	if (form && commSection) {
		document.documentElement.classList.add('js');

		const toggles = commSection.querySelectorAll<HTMLInputElement>('[data-comm-toggle]');
		const fields = commSection.querySelectorAll<HTMLElement>('[data-comm-field]');
		const commError = commSection.querySelector<HTMLElement>('[data-comm-error]');

		function syncCommFields() {
			toggles.forEach((toggle) => {
				const key = toggle.dataset.commToggle;
				const field = commSection.querySelector<HTMLElement>(`[data-comm-field="${key}"]`);
				const input = field?.querySelector<HTMLInputElement>('[data-comm-input]');
				const visible = toggle.checked;

				field?.classList.toggle('is-visible', visible);

				if (input) {
					if (visible) {
						input.removeAttribute('disabled');
					} else {
						input.setAttribute('disabled', 'disabled');
						input.setCustomValidity('');
					}
				}
			});
		}

		toggles.forEach((toggle) => {
			toggle.addEventListener('change', () => {
				commError?.setAttribute('hidden', '');
				syncCommFields();
			});
		});

		syncCommFields();

		function validateCommunication(): boolean {
			const selected = [...toggles].filter((toggle) => toggle.checked);

			if (selected.length === 0) {
				commError?.removeAttribute('hidden');
				toggles[0]?.focus();
				return false;
			}

			commError?.setAttribute('hidden', '');

			let valid = true;

			selected.forEach((toggle) => {
				const key = toggle.dataset.commToggle;
				const field = commSection.querySelector<HTMLElement>(`[data-comm-field="${key}"]`);
				const input = field?.querySelector<HTMLInputElement>('[data-comm-input]');

				if (!input) return;

				const value = input.value.trim();

				if (!value) {
					input.setCustomValidity('Bitte Angabe ergänzen.');
					valid = false;
					return;
				}

				if (key === 'email' && !input.checkValidity()) {
					input.setCustomValidity('Bitte gültige E-Mail-Adresse angeben.');
					valid = false;
					return;
				}

				input.setCustomValidity('');
			});

			if (!valid) {
				const firstInvalid = commSection.querySelector<HTMLInputElement>(
					'[data-comm-input]:invalid',
				);
				firstInvalid?.reportValidity();
			}

			return valid;
		}

		form.addEventListener('submit', (event) => {
			if (!validateCommunication()) {
				event.preventDefault();
			}
		});
	}
</script>

<style>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
