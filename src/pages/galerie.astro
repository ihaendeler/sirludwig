---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getCanonical } from '../config/site';

const path = '/galerie';
const placeholderIntro =
	'Dieser Bereich ist vorbereitet und wird in einer späteren Phase ausgearbeitet.';
---

<BaseLayout
	title="Galerie — Platzhalter"
	description="Bereich Galerie — in Vorbereitung."
	canonical={getCanonical(path)}
>
	<PageHero
		label="Bereich"
		title="Galerie"
		intro={placeholderIntro}
		headingId="page-heading"
	/>
</BaseLayout>
