---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig, getCanonical } from '../config/site';
import {
	getCertificateUrl,
	getHealthItemStatusLabel,
	healthCategoryLabels,
	healthDocumentationProgress,
	healthOverviewGroups,
	healthOverviewIntro,
	healthPendingStatusLabels,
	healthRecords,
} from '../data/health';
import '../styles/gesundheit.css';

const path = '/gesundheit';

const pageTitle = `Gesundheit & Untersuchungen — ${siteConfig.brandName}`;
const pageDescription =
	'Transparente Übersicht der genetischen, orthopädischen und augenärztlichen Untersuchungen von Sir Ludwig — Ergebnisse verständlich erklärt, Originalzertifikate als offizieller Nachweis.';
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={getCanonical(path)}>
	<PageHero
		title="Gesundheit"
		intro="Untersuchungsergebnisse werden hier verständlich eingeordnet. Originalzertifikate dienen als offizieller Nachweis."
		headingId="health-heading"
	/>

	<section class="health-section" aria-labelledby="health-overview-heading">
		<div class="container">
			<header class="health-section__header">
				<p class="health-eyebrow">Übersicht</p>
				<h2 id="health-overview-heading" class="health-title">Dokumentationsstand</h2>
				<p class="health-text health-text--wide">{healthOverviewIntro}</p>
			</header>

			<div class="health-progress" aria-label="Fortschritt der Dokumentation">
				{
					healthDocumentationProgress.map((category) => {
						const percent =
							category.total > 0 ? Math.round((category.completed / category.total) * 100) : 0;

						return (
							<div class="health-progress__row">
								<div class="health-progress__header">
									<span class="health-progress__label">{category.title}</span>
									<span class="health-progress__count">
										{category.completed} von {category.total} Untersuchungen abgeschlossen
									</span>
								</div>
								<div
									class="health-progress__track"
									role="progressbar"
									aria-valuenow={category.completed}
									aria-valuemin={0}
									aria-valuemax={category.total}
									aria-label={`${category.title}: ${category.completed} von ${category.total} abgeschlossen`}
								>
									<div class="health-progress__fill" style={`width: ${percent}%`} />
								</div>
							</div>
						);
					})
				}
			</div>

			<div class="health-overview">
				{
					healthOverviewGroups.map((group) => (
						<section class="health-overview-group" aria-label={group.title}>
							<h3 class="health-overview-group__title">{group.title}</h3>
							<div class="health-overview-group__rule" aria-hidden="true" />

							{
								group.subsections ? (
									group.subsections.map((subsection) => (
										<div class="health-overview-subsection">
											<h4 class="health-overview-subsection__title">{subsection.title}</h4>
											<ul class="health-overview-list">
												{
													subsection.items.map((item) => (
														<li class="health-overview-list__item">
															<span
																class:list={[
																	'health-overview-list__icon',
																	item.completed && 'health-overview-list__icon--done',
																]}
																aria-hidden="true"
															>
																{item.completed ? '✓' : '○'}
															</span>
															<a
																class="health-overview-list__label health-overview-list__label--link"
																href={`#health-${item.targetId}`}
															>
																{item.label}
															</a>
															<span class="visually-hidden">
																{getHealthItemStatusLabel(item, group.pendingStatus)}
															</span>
														</li>
													))
												}
											</ul>
										</div>
									))
								) : (
									<ul class="health-overview-list">
										{
											group.items?.map((item) => (
												<li class="health-overview-list__item">
													<span
														class:list={[
															'health-overview-list__icon',
															item.completed && 'health-overview-list__icon--done',
														]}
														aria-hidden="true"
													>
														{item.completed ? '✓' : '○'}
													</span>
													<a
														class="health-overview-list__label health-overview-list__label--link"
														href={`#health-${item.targetId}`}
													>
														{item.label}
													</a>
													<span class="visually-hidden">
														{getHealthItemStatusLabel(item, group.pendingStatus)}
													</span>
												</li>
											))
										}
									</ul>
								)
							}

							{
								group.pendingStatus && (
									<p class="health-overview-group__status">
										<span class="health-overview-group__status-label">Status</span>
										<span class="health-overview-group__status-value">
											○ {healthPendingStatusLabels[group.pendingStatus]}
										</span>
									</p>
								)
							}
						</section>
					))
				}
			</div>
		</div>
	</section>

	<section class="health-section" aria-labelledby="health-details-heading">
		<div class="container">
			<header class="health-section__header">
				<p class="health-eyebrow">Einzelergebnisse</p>
				<h2 id="health-details-heading" class="health-title">Untersuchungen im Detail</h2>
				<p class="health-text">
					Kurzbewertung und zuchtrelevante Einordnung — ergänzt durch die Originalzertifikate.
				</p>
			</header>

			<div class="health-details">
				{
					healthRecords.map((record, index) => {
						const previousCategory = index > 0 ? healthRecords[index - 1].category : null;
						const showCategory = record.category !== previousCategory;
						const certificateUrl = getCertificateUrl(record.pdf);

						return (
							<article
								class:list={['health-detail', !record.completed && 'health-detail--pending']}
								id={`health-${record.id}`}
								aria-labelledby={`health-${record.id}-title`}
							>
								{showCategory && (
									<p class="health-detail__category">{healthCategoryLabels[record.category]}</p>
								)}

								<h3 class="health-detail__title" id={`health-${record.id}-title`}>
									{record.title}
								</h3>

								{record.completed ? (
									<>
										<dl class="health-detail__meta">
											<div class="health-detail__row">
												<dt>Status</dt>
												<dd>
													<span class="health-detail__status health-detail__status--done">
														✓ Abgeschlossen
													</span>
												</dd>
											</div>
											<div class="health-detail__row">
												<dt>Ergebnis</dt>
												<dd class="health-detail__result">{record.result}</dd>
											</div>
											<div class="health-detail__row">
												<dt>Kurzbewertung</dt>
												<dd>{record.summary}</dd>
											</div>
											<div class="health-detail__row">
												<dt>Zuchtrelevanz</dt>
												<dd>{record.breeding}</dd>
											</div>
											<div class="health-detail__row">
												<dt>Untersuchungsdatum</dt>
												<dd>{record.date}</dd>
											</div>
										</dl>

										<div class="health-detail__actions">
											<a
												class="health-detail__link"
												href={certificateUrl}
												target="_blank"
												rel="noopener noreferrer"
											>
												Originalzertifikat ansehen →
											</a>
											<a class="health-detail__link" href={certificateUrl} download>
												PDF herunterladen
											</a>
										</div>
									</>
								) : (
									<div class="health-detail__pending">
										<p class="health-detail__pending-label">Status</p>
										<p class="health-detail__status health-detail__status--pending">
											○ Ausstehend
										</p>
										<p class="health-detail__pending-text">
											Das Untersuchungsergebnis liegt derzeit noch nicht vor.
										</p>
									</div>
								)}
							</article>
						);
					})
				}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
