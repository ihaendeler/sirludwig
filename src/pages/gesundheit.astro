---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { siteConfig, getCanonical } from '../config/site';
import {
	getCertificateUrl,
	getHealthRecord,
	healthNavGroups,
	healthReportSections,
} from '../data/health';
import '../styles/gesundheit.css';

const path = '/gesundheit';

const pageTitle = `Gesundheit & Untersuchungen — ${siteConfig.brandName}`;
const pageDescription =
	'Transparente Übersicht der genetischen, orthopädischen und augenärztlichen Untersuchungen von Sir Ludwig — Ergebnisse verständlich erklärt, Originalzertifikate als offizieller Nachweis.';
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={getCanonical(path)}>
	<PageHero
		title="Gesundheit"
		intro="Untersuchungsergebnisse werden hier verständlich eingeordnet. Originalzertifikate dienen als offizieller Nachweis."
		headingId="health-heading"
	/>

	<section class="health-section" aria-labelledby="health-nav-heading">
		<div class="container">
			<header class="health-section__header">
				<h2 id="health-nav-heading" class="health-title">Untersuchungsbereiche</h2>
			</header>

			<nav class="health-nav" aria-label="Untersuchungsbereiche">
				{
					healthNavGroups.map((group) => (
						<div class="health-nav__group">
							<h3 class="health-nav__group-title">{group.title}</h3>

							{
								group.subsections ? (
									group.subsections.map((subsection) => (
										<div class="health-nav__subsection">
											<p class="health-nav__subsection-label">{subsection.title}:</p>
											<ul class="health-nav__list">
												{
													subsection.items.map((item) => (
														<li class="health-nav__item">
															<a class="health-nav__link" href={`#health-${item.id}`}>
																{item.label}
															</a>
														</li>
													))
												}
											</ul>
										</div>
									))
								) : (
									<ul class="health-nav__list">
										{
											group.items?.map((item) => (
												<li class="health-nav__item">
													<a class="health-nav__link" href={`#health-${item.id}`}>
														{item.label}
													</a>
												</li>
											))
										}
									</ul>
								)
							}
						</div>
					))
				}
			</nav>
		</div>
	</section>

	<section class="health-section" aria-labelledby="health-details-heading">
		<div class="container">
			<header class="health-section__header">
				<h2 id="health-details-heading" class="health-title">Einzelergebnisse</h2>
			</header>

			<div class="health-report">
				{
					healthReportSections.map((section) => (
						<section
							class="health-area health-area--report"
							id={`health-area-${section.id}`}
							aria-labelledby={`health-report-${section.id}`}
						>
							<header class="health-area__header">
								<h3 class="health-area__title" id={`health-report-${section.id}`}>
									{section.title}
								</h3>
								<p class="health-area__intro">{section.intro}</p>
							</header>

							{
								section.pendingNotice ? (
									<div class="health-pending">
										<p class="health-pending__notice">{section.pendingNotice}</p>
										<ul class="health-pending__list">
											{
												section.recordIds?.map((recordId) => {
													const record = getHealthRecord(recordId);
													return (
														<li class="health-pending__item" id={`health-${record.id}`}>
															{record.navLabel}
														</li>
													);
												})
											}
										</ul>
									</div>
								) : (
									<>
										{
											section.subsections?.map((subsection) => (
												<div class="health-area__subsection health-area__subsection--report">
													<h4 class="health-area__subsection-title">{subsection.title}</h4>
													<table class="health-table">
														<thead>
															<tr>
																<th scope="col">Untersuchung</th>
																<th scope="col">Ergebnis</th>
															</tr>
														</thead>
														<tbody>
															{
																subsection.recordIds.map((recordId) => {
																	const record = getHealthRecord(recordId);
																	const certificateUrl = getCertificateUrl(record.pdf);

																	return (
																		<tr class="health-table__row">
																			<th scope="row" class="health-table__name-cell">
																				<a
																					class="health-table__name"
																					href={certificateUrl}
																					target="_blank"
																					rel="noopener noreferrer"
																				>
																					{record.tableLabel}
																				</a>
																			</th>
																			<td class="health-table__result">
																				{record.tableResult}
																			</td>
																		</tr>
																	);
																})
															}
														</tbody>
													</table>
												</div>
											))
										}
										{
											section.id === 'genetik' && (
												<p class="health-table__note">
													Untersuchungsdatum: 09.07.2026. Untersuchungsnamen verlinken auf
													die jeweiligen Originalzertifikate.
												</p>
											)
										}
										{
											section.id === 'genetik' && (
												<div class="health-accordions">
													<h4 class="health-accordions__heading">Erläuterungen</h4>
													{
														section.subsections?.map((subsection) => (
															<div class="health-accordions__group">
																<p class="health-accordions__group-title">
																	{subsection.title}
																</p>
																<div class="health-accordions__list">
																	{
																		subsection.recordIds.map((recordId) => {
																			const record = getHealthRecord(recordId);
																			const certificateUrl = getCertificateUrl(
																				record.pdf,
																			);

																			return (
																				<details
																					class="health-accordion"
																					id={`health-${record.id}`}
																				>
																					<summary class="health-accordion__summary">
																						<span class="health-accordion__header">
																							<span class="health-accordion__title">
																								{record.tableLabel}
																							</span>
																							<span class="health-accordion__result">
																								Ergebnis: {record.tableResult}
																							</span>
																						</span>
																						<span
																							class="health-accordion__icon"
																							aria-hidden="true"
																						/>
																					</summary>
																					<div class="health-accordion__content">
																						<div class="health-accordion__content-inner">
																							<dl class="health-accordion__meta">
																								<div class="health-accordion__row">
																									<dt>Kurzbewertung</dt>
																									<dd>{record.summary}</dd>
																								</div>
																								<div class="health-accordion__row">
																									<dt>Zuchtrelevanz</dt>
																									<dd>{record.breeding}</dd>
																								</div>
																								<div class="health-accordion__row">
																									<dt>Untersuchungsdatum</dt>
																									<dd>{record.date}</dd>
																								</div>
																								<div class="health-accordion__row">
																									<dt>Zertifikat</dt>
																									<dd class="health-accordion__links">
																										<a
																											class="health-accordion__link"
																											href={certificateUrl}
																											target="_blank"
																											rel="noopener noreferrer"
																										>
																											Originalzertifikat ansehen →
																										</a>
																										<a
																											class="health-accordion__link"
																											href={certificateUrl}
																											download={record.pdf}
																										>
																											PDF herunterladen
																										</a>
																									</dd>
																								</div>
																							</dl>
																						</div>
																					</div>
																				</details>
																			);
																		})
																	}
																</div>
															</div>
														))
													}
												</div>
											)
										}
									</>
								)
							}
						</section>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	function openHealthAccordionFromHash() {
		const id = window.location.hash.slice(1);
		if (!id.startsWith('health-')) return;

		const target = document.getElementById(id);
		if (!(target instanceof HTMLDetailsElement)) return;

		target.open = true;
		target.scrollIntoView({ behavior: 'smooth', block: 'start' });
	}

	openHealthAccordionFromHash();
	window.addEventListener('hashchange', openHealthAccordionFromHash);
</script>
