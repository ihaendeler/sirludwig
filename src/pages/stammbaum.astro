---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getCanonical } from '../config/site';

const path = '/stammbaum';
const placeholderIntro =
	'Dieser Bereich ist vorbereitet und wird in einer späteren Phase ausgearbeitet.';
---

<BaseLayout
	title="Stammbaum — Platzhalter"
	description="Bereich Stammbaum — in Vorbereitung."
	canonical={getCanonical(path)}
>
	<PageHero
		label="Bereich"
		title="Stammbaum"
		intro={placeholderIntro}
		headingId="page-heading"
	/>
</BaseLayout>
