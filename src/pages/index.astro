---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Platzhalter — Mobile First"
	description="Mobile-First Fundament für die zukünftige Website."
>
	<section class="hero" aria-labelledby="hero-heading">
		<div class="hero__inner container">
			<p class="hero__eyebrow">Platzhalter</p>
			<h1 id="hero-heading">Hochwertiger Hero-Bereich</h1>
			<p class="lead">
				Dieser Bereich ist ein struktureller Platzhalter für die spätere
				Startseite — optimiert für Smartphones und Besucher von Instagram.
			</p>
			<div class="hero__actions">
				<a href="#bereich" class="btn btn--primary">Platzhalter Aktion</a>
				<a href="#kontakt" class="btn btn--secondary">Mehr erfahren</a>
			</div>
		</div>
	</section>
</BaseLayout>
