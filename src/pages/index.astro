---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import '../styles/home.css';

import heroImage from '../assets/images/hero/PXL_20260516_084223542.jpg';
// Profilansicht — ruhiger Zuschnitt für Stammbaum-Teaser
import stammbaumImage from '../assets/images/ludwig/PXL_20260516_084222134.jpg';
// Liegt entspannt; bei 5:6-Zuschnitt können Vorderläufe abgeschnitten werden — ggf. eigenes Crop
import gesundheitImage from '../assets/images/ludwig/PXL_20260516_085447844.jpg';
// Mit Betreuerin; bei schmalem Viewport Schultern/Haaransatz im Blick behalten (center 24%)
import galerieImage from '../assets/images/galerie/PXL_20260516_084843156.jpg';
// Sonnenlicht, entspannt — bewusst anderes Motiv als Hero
import highlightImage from '../assets/images/ausstellungen/PXL_20260516_085447844.jpg';

const mobileWidths = [480, 640, 828, 1080, 1280, 1920];

const features = [
	{
		title: 'Stammbaum',
		href: '/stammbaum',
		teaser:
			'Abstammung und Linienführung im Überblick. Die Dokumentation wird mit dem Registerprojekt ergänzt.',
		image: stammbaumImage,
		alt: 'Sir Ludwig im Profil auf einer Wiese',
		position: 'center 30%',
		sizes: '(min-width: 64rem) 30vw, 100vw',
	},
	{
		title: 'Gesundheit',
		href: '/gesundheit',
		teaser:
			'Untersuchungen und Gesundheitsüberwachung im Rahmen der Entwicklung. Ergebnisse folgen nach Abschluss.',
		image: gesundheitImage,
		alt: 'Sir Ludwig entspannt auf einer Decke im Gras',
		position: 'center 38%',
		sizes: '(min-width: 64rem) 30vw, 100vw',
	},
	{
		title: 'Galerie',
		href: '/galerie',
		teaser:
			'Einblicke in Typ, Haltung und Alltag — visuell dokumentiert, ohne Übertreibung.',
		image: galerieImage,
		alt: 'Sir Ludwig mit Betreuerin auf einer Sommerwiese',
		position: 'center 24%',
		sizes: '(min-width: 64rem) 30vw, 100vw',
	},
];

const profileFields = [
	{ label: 'Geboren', value: 'xx.xx.xxxx' },
	{ label: 'Farbe', value: 'Tuxedo Apricot-Weiß' },
	{ label: 'Größe', value: 'in Entwicklung' },
	{ label: 'Gewicht', value: 'in Entwicklung' },
	{ label: 'Registrierung', value: 'FRZ — Registerprojekt' },
	{ label: 'Wohnort / Region', value: 'folgt' },
];

const timelineEntries = [
	{ phase: '2025', heading: 'Geburt' },
	{ phase: '2026', heading: 'Registerverfahren & Gesundheitstests' },
	{ phase: '2026', heading: 'ZTP & Ausstellungen' },
	{ phase: '2027', heading: 'Erste Nachzucht — geplant' },
];
---

<BaseLayout
	title={`${siteConfig.brandName} — ${siteConfig.heroSubtitle}`}
	description="Sir Ludwig — Tuxedo Großpudel by Flying Royals. Dokumentation von Abstammung, Entwicklung und Gesundheitsüberwachung."
>
	<!-- 1. Hero -->
	<section class="home-hero" aria-labelledby="home-hero-brand">
		<div class="home-hero__media home-media">
			<Image
				src={heroImage}
				alt="Sir Ludwig sitzt aufmerksam auf einer Wiese"
				widths={mobileWidths}
				sizes="100vw"
				loading="eager"
				fetchpriority="high"
				decoding="async"
				class="home-media__img"
			/>
		</div>
		<div class="home-hero__content container">
			<h1 id="home-hero-brand" class="home-hero__brand">{siteConfig.brandName}</h1>
			<p class="home-hero__subtitle">{siteConfig.heroSubtitle}</p>
			<p class="home-hero__intro">
				Tuxedo Großpudel aus ausgewählten Linien. Dokumentation von Entwicklung,
				Gesundheit und zukünftigem Zuchteinsatz.
			</p>
		</div>
	</section>

	<!-- 2. Feature areas -->
	<section class="home-section home-features" aria-labelledby="features-heading">
		<div class="container">
			<header class="home-features__intro">
				<p class="section-eyebrow">Sir Ludwig</p>
				<h2 id="features-heading" class="section-title">Überblick</h2>
				<p class="home-section__lead">
					Die wesentlichen Bereiche — sachlich dokumentiert und schrittweise ergänzt.
				</p>
			</header>

			<div class="home-features__grid">
				{
					features.map((item) => (
						<article class="home-feature">
							<div
								class="home-feature__media home-media"
								style={`--media-position: ${item.position}`}
							>
								<Image
									src={item.image}
									alt={item.alt}
									widths={mobileWidths}
									sizes={item.sizes}
									loading="lazy"
									decoding="async"
									class="home-media__img"
								/>
							</div>
							<div class="home-feature__body">
								<hr class="home-feature__line" />
								<h3 class="home-feature__title">
									<a href={item.href} class="home-feature__link">
										{item.title}
									</a>
								</h3>
								<p class="home-feature__teaser">{item.teaser}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<!-- 3. Steckbrief -->
	<section class="home-section home-profile" aria-labelledby="profile-heading">
		<div class="container">
			<header class="home-profile__header">
				<p class="section-eyebrow">Daten</p>
				<h2 id="profile-heading" class="section-title">Steckbrief</h2>
				<p class="home-section__lead">
					Aktuelle Eckdaten. Offene Felder werden ergänzt, sobald die Werte vorliegen.
				</p>
			</header>

			<dl class="home-profile__grid">
				{
					profileFields.map((field) => (
						<div class="home-profile__cell">
							<dt class="home-profile__label">{field.label}</dt>
							<dd class="home-profile__value">{field.value}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</section>

	<!-- 4. Timeline -->
	<section class="home-section home-timeline" aria-labelledby="timeline-heading">
		<div class="container">
			<header class="home-timeline__header">
				<p class="section-eyebrow">Werdegang</p>
				<h2 id="timeline-heading" class="section-title">Entwicklung</h2>
				<p class="home-section__lead">
					Geplanter Werdegang — ohne verbindliche Zusage zu einzelnen Terminen.
				</p>
			</header>

			<ol class="home-timeline__track">
				{
					timelineEntries.map((entry) => (
						<li class="home-timeline__entry">
							<span class="home-timeline__marker" aria-hidden="true" />
							<div class="home-timeline__body">
								<p class="home-timeline__phase">{entry.phase}</p>
								<h3 class="home-timeline__heading">{entry.heading}</h3>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<!-- 5. Trust -->
	<section class="home-section home-trust" aria-labelledby="trust-heading">
		<div class="container">
			<div class="home-trust__inner">
				<h2 id="trust-heading" class="section-title">Dokumentation statt Versprechen</h2>
				<p class="home-trust__text">
					Gesundheit, Abstammung und Entwicklung werden Schritt für Schritt dokumentiert.
					Ergebnisse und Unterlagen werden nach Vorliegen veröffentlicht.
				</p>
			</div>
		</div>
	</section>

	<!-- 6. Highlight -->
	<section
		class="home-section home-highlight home-highlight--reverse"
		aria-labelledby="highlight-heading"
	>
		<div class="container">
			<div class="home-highlight__layout">
				<div
					class="home-highlight__media home-media"
					style="--media-position: center 38%"
				>
					<Image
						src={highlightImage}
						alt="Sir Ludwig entspannt im Sonnenlicht auf einer Decke"
						widths={mobileWidths}
						sizes="(min-width: 64rem) 50vw, 100vw"
						loading="lazy"
						decoding="async"
						class="home-media__img"
					/>
				</div>
				<div class="home-highlight__content">
					<p class="section-eyebrow">Einblick</p>
					<h2 id="highlight-heading" class="section-title">Ruhe und Präsenz</h2>
					<p class="home-highlight__text">
						Ausgeglichene Haltung, aufmerksames Wesen — Eigenschaften, die in der
						weiteren Entwicklung beobachtet und dokumentiert werden.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 7. Call to action -->
	<section class="home-section home-cta" aria-labelledby="cta-heading">
		<div class="container">
			<div class="home-cta__inner">
				<p class="home-cta__note">Kontakt</p>
				<h2 id="cta-heading" class="home-cta__title">Deckanfrage</h2>
				<p class="home-cta__text">
					Für spätere Anfragen — der Bereich wird vorbereitet.
				</p>
				<a href="/deckanfrage" class="btn btn--primary">Deckanfrage vorbereiten</a>
			</div>
		</div>
	</section>
</BaseLayout>
